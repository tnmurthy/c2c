# JustHireMe local development environment
#
# Copy to .env only if you need shell-level overrides. Most users should enter
# API keys in the desktop app settings instead.

# Optional local model endpoint
OLLAMA_URL=http://localhost:11434/v1

# Optional provider keys for local backend experiments
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# Experimental automation lab only
JHM_AUTO_APPLY=false
PLAYWRIGHT_CHROMIUM_EXECUTABLE=
